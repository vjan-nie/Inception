[mysqld]
# Listen to all interfaces so WordPress can conect
bind-address            = 0.0.0.0
port                    = 3306

# Standard patsh handled internaly by Alpine
user                    = mysql
pid-file                = /run/mysqld/mysqld.pid
socket                  = /run/mysqld/mysqld.sock
datadir                 = /var/lib/mysql

# Avoid MariaDB's inverted DNS resolution attemps on every connection
skip-networking         = 0
skip-name-resolve
